# Gateway
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=3000
WECHAT_TOKEN=replace-with-your-wechat-token
WECHAT_APP_ID=replace-with-your-test-account-app-id
WECHAT_APP_SECRET=replace-with-your-test-account-app-secret
WECHAT_ENCODING_AES_KEY=
WECHAT_ENCRYPT_MODE=plain
WECHAT_MAX_REPLY_CHARS=1400
WECHAT_FULL_CHUNK_CHARS=1000
PUBLIC_BASE_URL=https://your-public-tunnel-or-domain.example.com
ALLOWED_WECHAT_OPENIDS=replace-with-your-openid
TASK_DATABASE_PATH=./data/tasks.json

# Runner
GATEWAY_URL=http://127.0.0.1:3000
RUNNER_SHARED_SECRET=replace-with-random-runner-secret
PROJECT_ARTICAL=/path/to/your/project
CODEX_DEFAULT_SANDBOX=read-only
CODEX_WRITE_SANDBOX=workspace-write
CODEX_TASK_TIMEOUT_SECONDS=1800
RUNNER_POLL_INTERVAL_SECONDS=5
CODEX_RUNNER_LOG_DIR=./data/logs
CODEX_RUNNER_RESULT_DIR=./data/results
